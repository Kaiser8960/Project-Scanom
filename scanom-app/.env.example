// ============================================================
// scanom-app — Environment Variables (Expo React Native)
// ============================================================
// Copy this file to .env and fill in your actual values.
// NEVER commit .env to git. Only .env.example is tracked.
//
// cp .env.example .env
//
// ⚠️  EXPO RULE: Only variables prefixed with EXPO_PUBLIC_
//     are accessible inside the app code. Secret-only values
//     (like service keys) must NEVER go here — put them in
//     the backend .env instead.
// ============================================================

# ── BACKEND API ──────────────────────────────────────────────
# URL of your FastAPI backend.
# Development (local):     http://192.168.x.x:8000
#   → Use your machine's LAN IP (not localhost) so Expo Go
#     on your phone can reach the server.
#   → Find your IP: ipconfig (Windows) or ip addr (WSL2)
EXPO_PUBLIC_API_URL=http://192.168.1.6:8000

# ── SUPABASE ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project → Settings → API
# Only use the ANON (public) key here — NEVER the service key.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── APP CONFIG ───────────────────────────────────────────────
# Minimum confidence threshold for a valid scan (0.0 to 1.0).
EXPO_PUBLIC_CONFIDENCE_THRESHOLD=0.70

# Detection search radius in kilometers for the Risk Map screen.
EXPO_PUBLIC_NEARBY_RADIUS_KM=5
