# ============================================================
# scanom-backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git. Only .env.example is tracked.
#
# cp .env.example .env
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-secret-key-here

# ── JWT AUTH ─────────────────────────────────────────────────
# Used to sign and verify user session tokens.
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-this-with-a-random-64-char-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── AI DISEASE EXPLAINER ─────────────────────────────────────
# Gemini API key (free tier available at https://aistudio.google.com/app/apikey)
# Used by ai_explainer.py to generate disease overview, causes, and treatment text.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ── MODEL ────────────────────────────────────────────────────
# Path to the TFLite model file relative to the backend root.
# The file must be EfficientNetV2B0 exported with SELECT_TF_OPS.
MODEL_PATH=model/efficientnetv2b0.tflite
CLASS_NAMES_PATH=model/class_names.json

# ── SERVER ───────────────────────────────────────────────────
# Which host and port to run uvicorn on.
# For local development: HOST=127.0.0.1
# For Railway/Render deployment: HOST=0.0.0.0
HOST=0.0.0.0
PORT=8000

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# During development, use * to allow all (Expo Go uses random ports).
# In production, replace * with your deployed frontend URL.
ALLOWED_ORIGINS=*

# ── ENVIRONMENT ──────────────────────────────────────────────
# Set to "production" on Railway/Render deployments.
ENVIRONMENT=development

# ── OPEN-METEO ───────────────────────────────────────────────
# Open-Meteo is completely free with no API key required.
# Fetched directly from https://api.open-meteo.com/v1/forecast
# This entry is informational only — no key needed.
# OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
